APP_NAME=Food Waste Platform API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change_this_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
DATABASE_URL=postgresql+psycopg://food_waste_user:food_waste_password@localhost:5432/food_waste
CORS_ORIGINS=http://localhost:5173
MATCH_RADIUS_MILED=15